{
  "source": ["src/tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "src/styles/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables"
        }
      ]
    },
    "js": {
      "transformGroup": "js",
      "buildPath": "src/tokens/",
      "files": [
        {
          "destination": "generated.ts",
          "format": "typescript/es6-default"
        }
      ]
    }
  }
}
